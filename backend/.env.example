PORT=3001
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=intranet
DB_PASS=
DB_NAME=intranet_wtorre

JWT_SECRET=
JWT_ACCESS_EXPIRES=30m
JWT_REFRESH_EXPIRES=7d
ENCRYPTION_KEY=

CORS_ORIGINS=http://localhost:4201,http://127.0.0.1:4201
MSAL_REDIRECT_URI_WEB=http://localhost:4201

ADMIN_EMAIL=admin@grupowtorre.com
ADMIN_PASSWORD=

RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_AUTH_WINDOW_MS=900000

STORAGE_DIR=/www/wwwroot/IntranetWTorre/intranet-wtorre/backend/storage/documentos
MAX_UPLOAD_MB=50

# RAMAL_AD_FIELD: legado; sync prioriza directory extension, fallback extensionAttribute5
GRAPH_SCHEMA_EXTENSION_ID=IntranetWtColaborador
# GRAPH_SCHEMA_EXTENSION_SKIP_REGISTER=1  # use se a extension já estiver registrada no Azure Portal
SYNC_COLABORADORES_MIN=60

# Azure Blob Storage (Managed Identity — sem connection string/chave)
AZURE_STORAGE_ACCOUNT=nubankparqueassets
TREINAMENTOS_CONTAINER=treinamentos
TREINAMENTOS_SAS_TTL_MIN=120
TREINAMENTOS_MAX_MB=1024
# TREINAMENTOS_TMP_DIR=/tmp/intranet-treinamentos

# Imagens do page builder (container público de leitura — provisionar manualmente no Azure)
PAGINAS_IMAGENS_CONTAINER=paginas
PAGINAS_IMAGENS_MAX_MB=5
PAGINAS_IMAGENS_UPLOAD_MAX_MB=25
# PAGINAS_IMAGENS_TMP_DIR=/tmp/intranet-paginas
# PAGINAS_IMAGENS_MAX_PX=2400
# PAGINAS_IMAGENS_TARGET_KB=1800

# Camarotes — fonte SharePoint (IT)
# URL de compartilhamento do xlsx (sem ?rtime=…)
CAMAROTES_FILE_SHARE_URL=
CAMAROTES_SHEET_CAMAROTE=Camarotes
# Frequência da sync automática: configurável no painel /admin/camarotes (não via env)

# E-mail digest de alertas
# CAMAROTES_MAILER=microservice|graph (default: microservice)
CAMAROTES_MAILER=microservice
CAMAROTES_MAIL_SERVICE_URL=
# Interim Graph (requer Application Access Policy + CAMAROTES_MAIL_FROM)
# CAMAROTES_MAILER=graph
CAMAROTES_MAIL_FROM=
CAMAROTES_MAIL_BATCH_SIZE=10
CAMAROTES_MAIL_BATCH_DELAY_MS=2000

# Eventos externos (widget Próximos eventos)
EVENTOS_CACHE_TTL_MIN=360
EVENTOS_LIMITE=6

# Power BI embed (App-owns-data) — habilitar com PBI_ENABLED=1
# PBI_ENABLED=0
# PBI_TENANT_ID=
# PBI_CLIENT_ID=
# PBI_CLIENT_SECRET=
# PBI_WORKSPACE_ID=
# PBI_RLS_MODE=static
# PBI_RLS_DYNAMIC_ROLE=
# PBI_SP_TOKEN_CACHE_MIN=50
# PBI_EMBED_TOKEN_CACHE_MIN=55
# PBI_EMBED_RATE_LIMIT_MAX=30
# PBI_EMBED_RATE_LIMIT_WINDOW_MS=900000
